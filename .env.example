# LiteLLM / LLM API Keys（至少填一个；可多填以支持 fallback）
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
# 国内大模型：阿里云 DashScope / 通义千问 Qwen
DASHSCOPE_API_KEY=

# Optional: use Redis for cache/session (leave empty to use in-memory)
REDIS_URL=

# MySQL 本地部署（不用 Docker）：先创建库 create database router;
DATABASE_URL=mysql+asyncmy://root:password@127.0.0.1:3306/router

# Server
HOST=0.0.0.0
PORT=8000

# Prometheus (for scraping this app's /metrics)
PROMETHEUS_MULTIPROC_DIR=./data/prometheus_multiproc
